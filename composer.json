{
    "name": "tcgunel/omnipay-yapikredi",
    "type": "library",
    "description": "Omnipay extension for Yapi Kredi (Posnet)",
    "keywords": [
        "yapikredi",
        "posnet",
        "omnipay",
        "payment",
        "gateway",
        "3d secure",
        "3d odeme",
        "sanal pos"
    ],
    "homepage": "https://github.com/tcgunel/omnipay-yapikredi",
    "license": "MIT",
    "authors": [
        {
            "name": "Tolga Can Gunel",
            "email": "tlgcngnl@gmail.com"
        },
        {
            "name": "Omnipay Contributors",
            "homepage": "https://github.com/tcgunel/omnipay-yapikredi/contributors"
        }
    ],
    "autoload": {
        "psr-4": {
            "Omnipay\\Yapikredi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Omnipay\\Yapikredi\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.0",
        "league/omnipay": "^3",
        "ext-simplexml": "*",
        "ext-dom": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9",
        "omnipay/tests": "^4",
        "brianium/paratest": "*",
        "fzaninotto/faker": "*",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.0"
    },
    "scripts": {
        "test": "vendor/bin/paratest --processes 6",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": "vendor/bin/pint",
        "lint-check": "vendor/bin/pint --test"
    }
}
